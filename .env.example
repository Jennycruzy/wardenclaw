# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=
APP_MODE=development

# ── LLM ───────────────────────────────────────────────────────────────────────
# Provider selection: explicit LLM_PROVIDER wins; else anthropic if ANTHROPIC_API_KEY,
# else openai if OPENAI_API_KEY, else disabled (deterministic/manual mode).
LLM_PROVIDER=anthropic
OPENAI_API_KEY=
# OpenAI-compatible gateway override. Point the openai provider at any
# OpenAI-compatible endpoint (Alibaba DashScope/Qwen, Together, Groq, ...).
# For Qwen: OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#           OPENAI_API_KEY=<your DashScope/Qwen key>  OPENAI_MODEL=qwen-plus
OPENAI_BASE_URL=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
STRATEGY_COMPILER_MODEL=
NEWS_SENTIMENT_MODEL=
AUDIT_SUMMARY_MODEL=
POST_TRADE_REFLECTION_MODEL=
LLM_TEMPERATURE=0.1
LLM_ENABLED=true

# ── Bitget xStock reactor (paper-trading submission) ──────────────────────────
# Live pause switch (read every cycle by the console + paper agent). Set to true
# to stop generating signal mandates without stopping the processes; set back to
# false to resume. No restart needed — takes effect on the next poll cycle.
REACTOR_PAUSED=false
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
BITGET_PUBLIC_BASE_URL=
BITGET_AGENT_HUB_BASE_URL=
# VERIFIED 2026-06-11: Bitget Demo Trading is FUTURES-ONLY (support article
# 12560603790031; spot endpoints under paptrading return "exchange environment
# is incorrect"). official_bitget_demo therefore CANNOT work for spot xStocks —
# use internal_paper_engine (real Agent Hub market data, simulated fills,
# honestly labeled), which the hackathon explicitly allows. Re-test a key with
# scripts/verify-bitget-demo-key.ts if Bitget ever ships spot demo trading.
BITGET_EXECUTION_MODE=internal_paper_engine
# Use the official Bitget Agent Hub MCP server (bitget-mcp-server, spawned via
# npx over stdio) as the perception source instead of the public REST client:
BITGET_AGENT_HUB_MCP=true
# Real per-equity news: Yahoo Finance RSS for each underlying US stock, classified
# by the configured LLM (NEWS_SENTIMENT_MODEL) into the reactor's sentiment gate.
# Set to false to disable. Without an LLM key headlines still show; events are
# honestly absent and the deterministic gates run alone.
BITGET_NEWS_FEED=true
BITGET_NEWS_TTL_SECONDS=300
BITGET_POLL_SECONDS=
BITGET_CANDLE_GRANULARITY=
BITGET_CYCLES=
# Reactor thresholds (all optional; defaults in reactor.ts). Calibrate with
# scripts/calibrate-bitget-reactor.ts against real history before changing.
# Shock = |return| ≥ MIN_MAGNITUDE (fraction) over WINDOW bars on ≥ MIN_VOLUME_RATIO×
# volume. Exits: TAKE_PROFIT_PCT target, MAX_HOLD_BARS time stop, volatility stop,
# and the watchdog sentiment-reversal exit (close a long when a classified
# real-news event turns negative with ≥ SENTIMENT_EXIT_CONFIDENCE confidence).
# Recalibrated 2026-06-11 over 13.9d of real history: loose thresholds (1.0–1.5%)
# produced 16–22 trades and ALL lost money (-1.8% to -3.9%); only selective ≥2%
# shocks were net positive. Selectivity wins — don't chase activity.
BITGET_SHOCK_MIN_MAGNITUDE_PCT=0.02
BITGET_SHOCK_MIN_VOLUME_RATIO=1.5
BITGET_TAKE_PROFIT_PCT=0.015
BITGET_MAX_HOLD_BARS=48
BITGET_SENTIMENT_EXIT_CONFIDENCE=0.65
#BITGET_SHOCK_WINDOW_BARS=3
#BITGET_COOLDOWN_BARS=2
#BITGET_MIN_INDEX_SUPPORT=0.4
#BITGET_MIN_ENTRY_SCORE=65
#BITGET_MAX_SINGLE_STOCK_PCT=0.5

# ── Deterministic risk gates & micro-capital economics ────────────────────────
# These are the non-negotiable knobs the risk engine enforces at execution time;
# the LLM cannot bypass them. Tune net-edge from calibration.
NET_EDGE_MIN_BPS=30                # tune from calibration
FRICTION_BUDGET_BPS=120
SCORING_SIM_COST_BPS=10            # per trade leg, conservative default
MAX_SLIPPAGE_BPS=50
SHADOW_FILL_TOLERANCE_BPS=40
KELLY_FRACTION=0.25
PER_TRADE_RISK_PCT=3
STOP_ATR_MULTIPLE=1.5
MAX_POSITION_PCT=70
SOFT_DRAWDOWN_PCT=4
MAX_DAILY_DRAWDOWN_PCT=6

# ── Calibration (score → expected-move mapping) ───────────────────────────────
CALIBRATION_SAMPLES_PATH=data/calibration/samples.json
CALIBRATION_REPORT_PATH=data/calibration/report.json
CALIBRATION_HISTORY_DAYS=30
CALIBRATION_MAX_AGE_DAYS=7

# ── Ops ───────────────────────────────────────────────────────────────────────
# Optional token gating the dashboard's command bridge to the live console.
DASHBOARD_COMMAND_TOKEN=
ALERT_WEBHOOK_URL=
